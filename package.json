{
	"name": "personaxi-front",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "npm run sync:branding && vite dev --host",
		"sync:branding": "pwsh -File ./scripts/generate-static-legal-docs.ps1",
		"sync:legal-docs": "npm run sync:branding",
		"build": "npm run sync:branding && vite build",
		"build:android": "npm run sync:branding && vite build",
		"emu:start:android": "pwsh -File ./scripts/start-android-emulator.ps1",
		"cap:sync": "pnpm build:android && npx cap sync android",
		"cap:copy": "pnpm build:android && npx cap copy android",
		"cap:open:android": "npx cap open android",
		"cap:run:android": "pwsh -File ./scripts/run-capacitor-android.ps1",
		"cap:run:android:dev": "pwsh -File ./scripts/run-capacitor-android-dev.ps1",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "npm run sync:branding && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "npm run sync:branding && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@capacitor/cli": "^8.2.0",
		"@pixiv/three-vrm": "^3.4.1",
		"@pixiv/three-vrm-core": "^3.4.1",
		"@pixiv/three-vrm-materials-mtoon": "^3.4.1",
		"@sveltejs/adapter-auto": "^6.0.1",
		"@sveltejs/adapter-static": "^3.0.8",
		"@sveltejs/kit": "^2.21.2",
		"@sveltejs/vite-plugin-svelte": "^5.1.0",
		"@types/dom-speech-recognition": "^0.0.7",
		"@types/three": "0.167.0",
		"esbuild": "0.25.4",
		"svelte": "^5.33.14",
		"svelte-check": "^4.2.1",
		"three": "^0.167.1",
		"typescript": "^5.8.3",
		"vite": "^6.3.5"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@tailwindcss/oxide",
			"esbuild"
		]
	},
	"dependencies": {
		"@astrodraw/astrochart": "^3.0.2",
		"@capacitor/android": "^8.2.0",
		"@capacitor/app": "^8.1.0",
		"@capacitor/browser": "^8.0.3",
		"@capacitor/core": "^8.2.0",
		"@capacitor/haptics": "^8.0.1",
		"@capacitor/keyboard": "^8.0.2",
		"@capacitor/splash-screen": "^8.0.1",
		"@capacitor/status-bar": "^8.0.2",
		"@capgo/capacitor-social-login": "^8.3.9",
		"@ffmpeg/ffmpeg": "^0.12.15",
		"@ffmpeg/util": "^0.12.2",
		"@gltf-transform/core": "^4.1.4",
		"@iconify/svelte": "^5.0.0",
		"@supabase/supabase-js": "^2.84.0",
		"@tailwindcss/vite": "^4.1.8",
		"bits-ui": "^2.4.1",
		"chinese-calendar": "^1.0.3",
		"circular-natal-horoscope-js": "^1.1.0",
		"eventsource-parser": "^3.0.3",
		"github-markdown-css": "^5.8.1",
		"isomorphic-dompurify": "^2.34.0",
		"jszip": "^3.10.1",
		"lunisolar": "^2.6.0",
		"marked": "^15.0.12",
		"marked-alert": "^2.1.2",
		"moment": "^2.30.1",
		"moment-timezone": "^0.6.0",
		"socket.io-client": "^4.8.1",
		"svelte-i18n": "^4.0.1",
		"tailwindcss": "^4.1.8",
		"tailwindcss-animate": "^1.0.7",
		"three-stdlib": "^2.36.0",
		"up": "^1.0.2",
		"uuid": "^11.1.0"
	}
}
